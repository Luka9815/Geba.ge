---

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <span class="hero-tag">საქართველოს ბიოტექნოლოგიის ასოციაცია</span>
      <h1 class="hero-heading"><span class="red">ბიოტექნოლოგიის</span> განვითარება საქართველოში</h1>
      <p class="hero-sub">ვაერთიანებთ მკვლევრებს, სპეციალისტებსა და სტუდენტებს ჯანდაცვის, სოფლის მეურნეობისა და გარემოს სფეროებში ინოვაციების სტიმულირებისთვის.</p>
      <div class="hero-ctas">
        <a href="/pages/projects-ge.html" class="btn-primary">ჩვენი პროექტები</a>
        <a href="/pages/about-ge.html" class="btn-outline">ჩვენ შესახებ</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="focus-grid">
        <div class="focus-card"><div class="focus-icon">🌾</div><div class="focus-label">სოფლის მეურნეობა</div></div>
        <div class="focus-card focus-card--red"><div class="focus-icon">🌿</div><div class="focus-label">გარემო</div></div>
        <div class="focus-card"><div class="focus-icon">🏥</div><div class="focus-label">ჯანდაცვა</div></div>
        <div class="focus-bridge"><div class="focus-bridge-line"></div><div class="focus-bridge-dot"></div><div class="focus-bridge-line"></div></div>
        <div class="focus-card focus-card--red"><div class="focus-icon">🍎</div><div class="focus-label">სურსათი</div></div>
        <div class="focus-card"><div class="focus-icon">📚</div><div class="focus-label">განათლება</div></div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<div class="wwd-section">
  <div class="wwd-section-inner">
  <h2 class="section-title">ჩვენი საქმიანობა</h2>
  <div class="what-we-do-grid">
    <div class="wwd-card">
      <div class="wwd-icon">🎓</div>
      <h3 class="wwd-title">ინოვაციური სასწავლო პროგრამები</h3>
      <p class="wwd-desc">მოკლევადიანი პროფესიული კურსები გარემოს, ჯანდაცვის, საკვებისა და სოფლის მეურნეობის სფეროებში, პრაქტიკული, სამუშაო ბაზარზე ორიენტირებული უნარ-ჩვევების განვითარებისთვის.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">🤝</div>
      <h3 class="wwd-title">სექტორთაშორისი თანამშრომლობა</h3>
      <p class="wwd-desc">ახალგაზრდული ორგანიზაციებს, სახელმწიფო სტრუქტურებს, უნივერსიტეტებსა და სხვა ინსტიტუციებს შემაერთებელი ერთობლივი ინიციატივები სემინარებისა და კონფერენციების მეშვეობით.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">📈</div>
      <h3 class="wwd-title">კომპეტენციებისა და დასაქმებადობის გაძლიერება</h3>
      <p class="wwd-desc">სამუშაო ბაზრის საჭიროებებზე მორგებული ინდუსტრიული ტრენინგები, არაფორმალური განათლებისა და პროფესიული განვითარების მხარდასაჭერად.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">🔗</div>
      <h3 class="wwd-title">დამსაქმებლებისა და სამუშაო მაძიებლების დაკავშირება</h3>
      <p class="wwd-desc">ონლაინ დასაქმებისა და კარიერული ხელმძღვანელობის პლატფორმა, რომელიც ახალგაზრდების დასაქმებადობის გასაუმჯობესებლად.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">💡</div>
      <h3 class="wwd-title">გახსნილი პარტნიორობისა და ახალი იდეებისთვის</h3>
      <p class="wwd-desc">აქტიური თანამშრომლობა პარტნიორებთან, ვინც ჩვენი ხედვა ზეგავლენის, ინოვაციებისა და მდგრადი განვითარების შესახებ გვიზიარებს.</p>
    </div>
  </div>
  </div>
</div>


<!-- LATEST NEWS -->
<div class="section-block">
  <div class="news-strip-header">
    <h2 class="section-title">სიახლეები</h2>
    <a href="/pages/news-ge.html" class="view-all">ყველა სიახლე →</a>
  </div>
  <div class="news-strip">
    {% for item in collections.news | reverse | limit(3) %}
    <article class="news-card">
      {% if item.data.cover %}
        <img src="{{ item.data.cover }}" alt="{{ item.data.title_ka | escape }}" class="news-card-img">
      {% else %}
        <div class="news-card-img"></div>
      {% endif %}
      <div class="news-card-body">
        {% if item.data.date %}<p class="news-date">{{ item.data.date | date("dd MMM yyyy") }}</p>{% endif %}
        <p class="news-headline"><a href="{{ item.data.permalink_ka }}">{{ item.data.title_ka }}</a></p>
      </div>
    </article>
    {% endfor %}
  </div>
</div>
