<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-left">
      <span class="hero-tag">Georgian Biotechnology Association</span>
      <h1 class="hero-heading"><span class="red">Advancing Biotech</span> in Georgia</h1>
      <p class="hero-sub">Uniting researchers, professionals, and students to drive innovation in health, agriculture, and environmental science across Georgia.</p>
      <div class="hero-ctas">
        <a href="/pages/projects.html" class="btn-primary">Our Projects</a>
        <a href="/pages/about.html" class="btn-outline">Learn More</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="focus-grid">
        <div class="focus-card"><div class="focus-icon">🌾</div><div class="focus-label">Agriculture</div></div>
        <div class="focus-card focus-card--red"><div class="focus-icon">🌿</div><div class="focus-label">Environment</div></div>
        <div class="focus-card"><div class="focus-icon">🏥</div><div class="focus-label">Health</div></div>
        <div class="focus-bridge"><div class="focus-bridge-line"></div><div class="focus-bridge-dot"></div><div class="focus-bridge-line"></div></div>
        <div class="focus-card focus-card--red"><div class="focus-icon">🍎</div><div class="focus-label">Food</div></div>
        <div class="focus-card"><div class="focus-icon">📚</div><div class="focus-label">Education</div></div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<div class="wwd-section">
  <div class="wwd-section-inner">
  <h2 class="section-title">What We Do</h2>
  <div class="what-we-do-grid">
    <div class="wwd-card">
      <div class="wwd-icon">🎓</div>
      <h3 class="wwd-title">Innovative Training Programs</h3>
      <p class="wwd-desc">Short-term professional courses in Environment, Health, Food, and Agriculture, designed to build practical, job-relevant skills.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">🤝</div>
      <h3 class="wwd-title">Cross-Sector Collaboration</h3>
      <p class="wwd-desc">Joint initiatives connecting youth organizations, NGOs, universities, and public institutions through workshops, seminars, and conferences.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">📈</div>
      <h3 class="wwd-title">Enhancing Competencies &amp; Employability</h3>
      <p class="wwd-desc">Industry-focused training aligned with labor market needs, supporting non-formal education and professional development.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">🔗</div>
      <h3 class="wwd-title">Connecting Employers &amp; Job Seekers</h3>
      <p class="wwd-desc">An online employment and career guidance hub bridging employers and job seekers to improve youth employability.</p>
    </div>
    <div class="wwd-card">
      <div class="wwd-icon">💡</div>
      <h3 class="wwd-title">Open to Partnerships &amp; New Ideas</h3>
      <p class="wwd-desc">Active collaboration with partners who share our vision for impact, innovation, and sustainable development.</p>
    </div>
  </div>
  </div>
</div>


<!-- LATEST NEWS -->
<div class="section-block">
  <div class="news-strip-header">
    <h2 class="section-title">Latest News</h2>
    <a href="/pages/news.html" class="view-all">View all →</a>
  </div>
  <div class="news-strip">
    {% for item in collections.news | reverse | limit(3) %}
    <article class="news-card">
      {% if item.data.cover %}
        <img src="{{ item.data.cover }}" alt="{{ item.data.title_en | escape }}" class="news-card-img">
      {% else %}
        <div class="news-card-img"></div>
      {% endif %}
      <div class="news-card-body">
        {% if item.data.date %}<p class="news-date">{{ item.data.date | date("dd MMM yyyy") }}</p>{% endif %}
        <p class="news-headline"><a href="{{ item.data.permalink_en }}">{{ item.data.title_en }}</a></p>
      </div>
    </article>
    {% endfor %}
  </div>
</div>
