---
layout: layouts/base.njk
pagination:
  data: collections.news
  size: 1
  alias: item
permalink: "{{ item.data.permalink_ka }}"
eleventyComputed:
  title: "{{ item.data.title_ka }} | GEBA"
  alt_url_en: "{{ item.data.permalink_en }}"
lang: ka
nav_active: news
---
<section class="project-content">
  <h2>{{ item.data.title_ka }}</h2>

  {% if item.data.cover %}
    <img src="{{ item.data.cover }}" class="proj-img" alt="{{ item.data.title_ka | escape }}">
  {% endif %}

  <div class="richtext">
    {% set body = item.data.body_ka | default("") %}
    {% set placeholder = "(Write the article content here. You can include images via the CMS upload button.)" %}

    {% if body and (body | trim) != placeholder %}
      {{ body | safe }}
    {% else %}
      {{ item.templateContent | safe }}
    {% endif %}
  </div>

  {% if item.data.gallery and item.data.gallery.length %}
  <section class="post-gallery">
    <h2>გალერეა</h2>
    <div class="gallery-grid">
      {% for image in item.data.gallery %}
      <a href="{{ image }}" class="glightbox">
        <img src="{{ image }}" alt="Gallery image {{ loop.index }}">
      </a>
      {% endfor %}
    </div>
    {% if item.data.gallery | length > 6 %}
    <button class="gallery-show-all">ყველა ფოტოს ჩვენება</button>
    {% endif %}
  </section>
  <script>
  (function() {
    var items = document.querySelectorAll('.gallery-grid a');
    for (var i = 6; i < items.length; i++) { items[i].style.display = 'none'; }
    var btn = document.querySelector('.gallery-show-all');
    if (btn) {
      btn.addEventListener('click', function() {
        for (var i = 6; i < items.length; i++) { items[i].style.display = ''; }
        btn.remove();
      });
    }
  })();
  </script>
  {% endif %}
</section>
