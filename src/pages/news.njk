---
layout: layouts/base.njk
title: "News | GEBA"
lang: en
nav_active: news
alt_url_ka: "/pages/news-ge.html"
permalink: "/pages/news.html"
---
<div class="page-hero">
  <div class="page-hero-inner">
    <h1>Latest News</h1>
    <p>Updates, events, and announcements from GeBA.</p>
  </div>
</div>

<div class="section-block">
  <div class="news-strip news-strip--full">
    {% for item in collections.news | reverse %}
    <article class="news-card">
      {% if item.data.cover %}
        <img src="{{ item.data.cover }}" alt="{{ item.data.title_en | escape }}" class="news-card-img">
      {% else %}
        <div class="news-card-img"></div>
      {% endif %}
      <div class="news-card-body">
        {% if item.data.date %}<p class="news-date">{{ item.data.date | date("dd MMM yyyy") }}</p>{% endif %}
        <p class="news-headline"><a href="{{ item.data.permalink_en }}">{{ item.data.title_en }}</a></p>
        <a class="news-read-more" href="{{ item.data.permalink_en }}">Read more →</a>
      </div>
    </article>
    {% endfor %}
  </div>
</div>
