---
layout: layouts/base.njk
pagination:
  data: collections.news
  size: 1
  alias: item
permalink: "{{ item.data.permalink_en }}"
eleventyComputed:
  title: "{{ item.data.title_en }} | GEBA"
  alt_url_ka: "{{ item.data.permalink_ka }}"
lang: en
nav_active: news
---
<section class="project-content">
  <h2>{{ item.data.title_en }}</h2>

  {% if item.data.cover %}
    <img src="{{ item.data.cover }}" class="proj-img" alt="{{ item.data.title_en | escape }}">
  {% endif %}

  <div class="richtext">
    {% set body = item.data.body_en | default("") %}
    {% set placeholder = "(Write the article content here. You can include images via the CMS upload button.)" %}

    {% if body and (body | trim) != placeholder %}
      {{ body | safe }}
    {% else %}
      {{ item.templateContent | safe }}
    {% endif %}
  </div>

  {% if item.data.gallery and item.data.gallery.length %}
  <section class="post-gallery">
    <h2>Gallery / გალერეა</h2>
    <div class="gallery-grid">
      {% for image in item.data.gallery %}
      <a href="{{ image }}" class="glightbox">
        <img src="{{ image }}" alt="Gallery image {{ loop.index }}">
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</section>
